<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/bench_form_title"
            android:textSize="24sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/benchNameInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/bench_name" />

        <EditText
            android:id="@+id/benchDescriptionInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/bench_description" />

        <EditText
            android:id="@+id/benchImageUrlInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/bench_image_url"
            android:inputType="textUri" />

        <EditText
            android:id="@+id/benchLatitudeInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/latitude"
            android:inputType="numberDecimal|numberSigned" />

        <EditText
            android:id="@+id/benchLongitudeInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/longitude"
            android:inputType="numberDecimal|numberSigned" />

        <Button
            android:id="@+id/saveBenchButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/save_bench" />

        <TextView
            android:id="@+id/benchFormStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="#B00020" />

    </LinearLayout>
</ScrollView>
