<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/jv_dark_blue">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Hero image + back button overlay -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/benchDetailImage"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:scaleType="centerCrop"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/backButton"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_margin="8dp"
                android:text="← Retour"
                android:textColor="@color/jv_orange"
                android:paddingStart="0dp" />

        </FrameLayout>

        <!-- Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/benchDetailNameText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/jv_text_on_dark"
                android:layout_marginBottom="6dp" />

            <View
                android:layout_width="40dp"
                android:layout_height="3dp"
                android:background="@color/jv_orange"
                android:layout_marginBottom="20dp" />

            <!-- Description card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#0F1A35"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Description"
                        android:textSize="12sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.12"
                        android:textColor="@color/jv_orange"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/benchDetailDescriptionText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/jv_text_on_dark"
                        android:textSize="15sp"
                        android:lineSpacingMultiplier="1.4" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Location card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#0F1A35"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Localisation"
                        android:textSize="12sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.12"
                        android:textColor="@color/jv_orange"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/benchDetailCoordinatesText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/jv_text_on_dark"
                        android:textSize="14sp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Rating card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#0F1A35"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Note"
                        android:textSize="12sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.12"
                        android:textColor="@color/jv_orange"
                        android:layout_marginBottom="10dp" />

                    <LinearLayout
                        android:id="@+id/starsRow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/reviewCountText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/jv_input_hint"
                        android:textSize="13sp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Reviews card (expandable) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#0F1A35"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="28dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Clickable header -->
                    <LinearLayout
                        android:id="@+id/reviewsHeader"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:id="@+id/reviewsHeaderLabel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Avis"
                            android:textSize="12sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.12"
                            android:textColor="@color/jv_orange" />

                        <TextView
                            android:id="@+id/reviewsToggleIcon"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="▼"
                            android:textColor="@color/jv_orange"
                            android:textSize="12sp" />

                    </LinearLayout>

                    <!-- Collapsible reviews list -->
                    <LinearLayout
                        android:id="@+id/reviewsContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/goReviewFormButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/add_review"
                android:textColor="@color/jv_text_on_orange"
                android:backgroundTint="@color/jv_orange"
                android:textStyle="bold"
                android:textSize="16sp"
                app:cornerRadius="12dp" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>
