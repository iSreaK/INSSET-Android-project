<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <TextView
        android:id="@+id/mapStatusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:text="@string/loading"
        android:textColor="@color/jv_text_on_dark" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <org.osmdroid.views.MapView
            android:id="@+id/mapView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/markerPopupCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:layout_margin="12dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/jv_card_background"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/popupImage"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:contentDescription="@string/bench_image_url"
                        android:scaleType="centerCrop" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/popupName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:maxLines="2"
                            android:textColor="@color/jv_text_on_card"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/popupMeta"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textColor="@color/jv_input_hint"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/popupCloseButton"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/action_back"
                        android:src="@android:drawable/ic_menu_close_clear_cancel"
                        app:tint="@color/jv_input_hint" />
                </LinearLayout>

                <Button
                    android:id="@+id/popupVoirPlusButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:backgroundTint="@color/jv_orange"
                    android:text="@string/action_view_more"
                    android:textColor="@color/jv_text_on_orange" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </FrameLayout>

    <Button
        android:id="@+id/goBenchFormButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="12dp"
        android:backgroundTint="@color/jv_orange"
        android:text="@string/add_bench"
        android:textColor="@color/jv_text_on_orange" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/mapBottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/jv_bottom_nav_background"
        app:itemIconTint="@color/jv_bottom_nav_item"
        app:itemTextColor="@color/jv_bottom_nav_item"
        app:menu="@menu/bottom_nav_menu" />

</LinearLayout>
