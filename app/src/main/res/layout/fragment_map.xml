<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Provider-agnostic container: the MapService implementation
             inflates its own native view (osmdroid MapView, GoogleMap
             SupportMapFragment, ...) and attaches it here. -->
        <FrameLayout
            android:id="@+id/mapContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <TextView
            android:id="@+id/mapStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/jv_card_background"
            android:padding="10dp"
            android:textColor="@color/jv_text_on_card"
            android:textSize="13sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/offlineBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:background="#CC5A1E1E"
            android:gravity="center"
            android:padding="10dp"
            android:text="@string/offline_banner"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/locateMeButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="16dp"
            android:contentDescription="@string/locate_me"
            android:src="@drawable/ic_my_location"
            app:backgroundTint="@color/jv_orange"
            app:tint="@color/jv_text_on_orange" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/nearbyFab"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_marginTop="96dp"
            android:layout_marginEnd="16dp"
            android:contentDescription="@string/nearby_button_label"
            android:src="@drawable/ic_nearby"
            app:backgroundTint="@color/jv_orange"
            app:tint="@color/jv_text_on_orange" />

        <Button
            android:id="@+id/goBenchFormButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="@color/jv_orange"
            android:text="@string/add_bench"
            android:textColor="@color/jv_text_on_orange" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/markerPopupCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:layout_margin="12dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/jv_card_background"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/popupImage"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:contentDescription="@string/bench_image_url"
                        android:scaleType="centerCrop" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/popupName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:maxLines="2"
                            android:textColor="@color/jv_text_on_card"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/popupMeta"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textColor="@color/jv_input_hint"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/popupCloseButton"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/action_back"
                        android:src="@android:drawable/ic_menu_close_clear_cancel"
                        app:tint="@color/jv_input_hint" />
                </LinearLayout>

                <Button
                    android:id="@+id/popupVoirPlusButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:backgroundTint="@color/jv_orange"
                    android:text="@string/action_view_more"
                    android:textColor="@color/jv_text_on_orange" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </FrameLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/mapBottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/jv_bottom_nav_background"
        app:itemIconTint="@color/jv_bottom_nav_item"
        app:itemTextColor="@color/jv_bottom_nav_item"
        app:menu="@menu/bottom_nav_menu" />

</LinearLayout>
