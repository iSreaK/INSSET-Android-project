<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/mapFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.insset.jvbench.ui.auth.LoginFragment"
        android:label="Login">
        <action
            android:id="@+id/action_loginFragment_to_registerFragment"
            app:destination="@id/registerFragment" />
        <action
            android:id="@+id/action_loginFragment_to_mapFragment"
            app:destination="@id/mapFragment" />
        <action
            android:id="@+id/action_loginFragment_to_accountFragment"
            app:destination="@id/accountFragment" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.insset.jvbench.ui.auth.RegisterFragment"
        android:label="Register">
        <action
            android:id="@+id/action_registerFragment_to_mapFragment"
            app:destination="@id/mapFragment" />
        <action
            android:id="@+id/action_registerFragment_to_accountFragment"
            app:destination="@id/accountFragment" />
    </fragment>

    <fragment
        android:id="@+id/mapFragment"
        android:name="com.insset.jvbench.ui.map.MapFragment"
        android:label="Map">
        <action
            android:id="@+id/action_mapFragment_to_loginFragment"
            app:destination="@id/loginFragment" />
        <action
            android:id="@+id/action_mapFragment_to_accountFragment"
            app:destination="@id/accountFragment" />
        <action
            android:id="@+id/action_mapFragment_to_benchFormFragment"
            app:destination="@id/benchFormFragment" />
        <action
            android:id="@+id/action_mapFragment_to_benchDetailFragment"
            app:destination="@id/benchDetailFragment" />
        <action
            android:id="@+id/action_mapFragment_to_settingsFragment"
            app:destination="@id/settingsFragment" />
        <action
            android:id="@+id/action_mapFragment_to_adminFragment"
            app:destination="@id/adminFragment" />
        <action
            android:id="@+id/action_mapFragment_to_nearbyBenchesFragment"
            app:destination="@id/nearbyBenchesFragment" />
    </fragment>

    <fragment
        android:id="@+id/accountFragment"
        android:name="com.insset.jvbench.ui.account.AccountFragment"
        android:label="Compte">
        <action
            android:id="@+id/action_accountFragment_to_mapFragment"
            app:destination="@id/mapFragment" />
        <action
            android:id="@+id/action_accountFragment_to_loginFragment"
            app:destination="@id/loginFragment" />
        <action
            android:id="@+id/action_accountFragment_to_registerFragment"
            app:destination="@id/registerFragment" />
        <action
            android:id="@+id/action_accountFragment_to_myBenchesFragment"
            app:destination="@id/myBenchesFragment" />
        <action
            android:id="@+id/action_accountFragment_to_settingsFragment"
            app:destination="@id/settingsFragment" />
        <action
            android:id="@+id/action_accountFragment_to_adminFragment"
            app:destination="@id/adminFragment" />
    </fragment>

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.insset.jvbench.ui.settings.SettingsFragment"
        android:label="Settings">
        <action
            android:id="@+id/action_settingsFragment_to_mapFragment"
            app:destination="@id/mapFragment" />
        <action
            android:id="@+id/action_settingsFragment_to_accountFragment"
            app:destination="@id/accountFragment" />
        <action
            android:id="@+id/action_settingsFragment_to_adminFragment"
            app:destination="@id/adminFragment" />
    </fragment>

    <fragment
        android:id="@+id/adminFragment"
        android:name="com.insset.jvbench.ui.admin.AdminFragment"
        android:label="Admin">
        <action
            android:id="@+id/action_adminFragment_to_mapFragment"
            app:destination="@id/mapFragment" />
        <action
            android:id="@+id/action_adminFragment_to_accountFragment"
            app:destination="@id/accountFragment" />
        <action
            android:id="@+id/action_adminFragment_to_settingsFragment"
            app:destination="@id/settingsFragment" />
    </fragment>

    <fragment
        android:id="@+id/benchFormFragment"
        android:name="com.insset.jvbench.ui.benchform.BenchFormFragment"
        android:label="Bench form">
        <argument
            android:name="benchId"
            android:defaultValue="@null"
            app:argType="string"
            app:nullable="true" />
        <argument
            android:name="prefilLat"
            android:defaultValue="0.0"
            app:argType="float" />
        <argument
            android:name="prefilLng"
            android:defaultValue="0.0"
            app:argType="float" />
    </fragment>

    <fragment
        android:id="@+id/benchDetailFragment"
        android:name="com.insset.jvbench.ui.benchdetail.BenchDetailFragment"
        android:label="Bench detail">
        <action
            android:id="@+id/action_benchDetailFragment_to_reviewFormFragment"
            app:destination="@id/reviewFormFragment" />
        <action
            android:id="@+id/action_benchDetailFragment_to_benchFormFragment"
            app:destination="@id/benchFormFragment" />
        <argument
            android:name="benchId"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/myBenchesFragment"
        android:name="com.insset.jvbench.ui.mybenches.MyBenchesFragment"
        android:label="Mes bancs">
        <action
            android:id="@+id/action_myBenchesFragment_to_benchDetailFragment"
            app:destination="@id/benchDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/reviewFormFragment"
        android:name="com.insset.jvbench.ui.reviewform.ReviewFormFragment"
        android:label="Review form">
        <argument
            android:name="benchId"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/nearbyBenchesFragment"
        android:name="com.insset.jvbench.ui.nearby.NearbyBenchesFragment"
        android:label="Bancs autour de vous">
        <action
            android:id="@+id/action_nearbyBenchesFragment_to_benchDetailFragment"
            app:destination="@id/benchDetailFragment" />
    </fragment>
</navigation>
